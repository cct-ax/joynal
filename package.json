{
  "name": "jornal",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nuxtjs/supabase": "^2.0.5",
    "nuxt": "4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.4.1",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "overrides": {
      "cac@^6.7.14": "6.7.14",
      "commander@^13.1.0": "13.1.0"
    },
    "onlyBuiltDependencies": ["@parcel/watcher", "esbuild", "unrs-resolver"]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "printWidth": 100
  }
}
