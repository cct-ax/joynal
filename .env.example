NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-anon-key
# Supabase の service_role（secret）key。@nuxtjs/supabase v2 はこの名前で読む（NUXT_SUPABASE_SERVICE_ROLE_KEY ではない）
NUXT_SUPABASE_SECRET_KEY=your-service-role-secret-key

# AI 機能（コーチング・週次サマリー）のプロバイダ設定。
# 値は NUXT_* 環境変数で上書きする（runtimeConfig 直下＝サーバー専用でクライアントに露出しない）。
# 既定プロバイダは Anthropic（Claude Haiku 4.5）。OpenAI も同一アダプタ（server/utils/aiChat）で利用可。
# Gemini は OpenAI 互換エンドポイント経由（provider='gemini'）。
NUXT_AI_PROVIDER=gemini
NUXT_GEMINI_API_KEY=your-gemini-api-key
NUXT_GEMINI_MODEL=gemini-2.5-flash
